# ==============================================================================
# Portfolio App - Environment Variables Configuration
# Copy this file to '.env' and modify variables as needed for your environment.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. WordPress CMS Integration
# ------------------------------------------------------------------------------

# The public URL of the WordPress CMS.
# For local Docker setup, this is http://localhost:8080
# For production, this should be the public domain of your WordPress instance.
WORDPRESS_URL="http://localhost:8080"

# The domain/hostname of your WordPress site (used by Next.js for remote image optimization).
# Must match the domain/hostname in WORDPRESS_URL (e.g., "localhost" or "wordpress.com").
WORDPRESS_HOSTNAME="localhost"

# ------------------------------------------------------------------------------
# 2. WordPress API Authentication
# ------------------------------------------------------------------------------

# The WordPress user account to authenticate API write operations (e.g. creating posts).
WP_USER="root"

# The WordPress application password generated specifically for this application.
# Generate this by running the following command in your terminal:
# docker exec -it portfolio-app-wordpress-1 wp user application-password create root "portfolio-app" --allow-root
WP_APPLICATION_PASSWORD="your-application-password-here"

# ------------------------------------------------------------------------------
# 3. Next.js Revalidation Webhook
# ------------------------------------------------------------------------------

# Secret key shared between WordPress and Next.js to secure revalidation webhooks.
# Generate a secure 32-character base64 secret using: openssl rand -base64 32
WORDPRESS_WEBHOOK_SECRET="your-revalidation-secret-here"

# ------------------------------------------------------------------------------
# 4. Database Connection (Local Host Development)
# ------------------------------------------------------------------------------

# Connection string used by Next.js if running outside Docker (e.g. 'pnpm dev' on host).
# Docker Compose maps MariaDB port 3306 inside the container to 3307 on the host.
DATABASE_URL="mysql://wordpress:wordpress@127.0.0.1:3307/wordpress"

